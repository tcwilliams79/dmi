{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DMI Releases Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "current_release_id",
    "releases"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_release_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "release_id",
          "data_through_label",
          "published_at",
          "status",
          "methodology_version",
          "summary",
          "summary_facts",
          "spec_urls",
          "metrics"
        ],
        "properties": {
          "release_id": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}$"
          },
          "data_through_label": {
            "type": "string"
          },
          "published_at": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": ["current", "superseded", "revised"]
          },
          "methodology_version": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "summary_facts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "overall_direction": {
                "type": "string"
              },
              "median_delta_mom": {
                "type": "number"
              },
              "stress_delta_mom": {
                "type": "number"
              },
              "spread_delta_mom": {
                "type": "number"
              },
              "tilt_delta_mom": {
                "type": "number"
              },
              "unemployment_delta_mom": {
                "type": "number"
              },
              "spread_direction": {
                "type": "string"
              },
              "most_pressured_group": {
                "type": "string",
                "pattern": "^Q[1-5]$"
              },
              "least_pressured_group": {
                "type": "string",
                "pattern": "^Q[1-5]$"
              },
              "lower_income_more_pressure": {
                "type": "boolean"
              },
              "higher_income_more_pressure": {
                "type": "boolean"
              },
              "pressure_similar_across_bottom_top": {
                "type": "boolean"
              }
            }
          },
          "spec_urls": {
            "type": "object",
            "additionalProperties": false,
            "required": ["baseline", "slack_plus", "core"],
            "properties": {
              "baseline": {
                "$ref": "#/$defs/spec_url_block"
              },
              "slack_plus": {
                "$ref": "#/$defs/spec_url_block"
              },
              "core": {
                "$ref": "#/$defs/spec_url_block"
              }
            }
          },
          "metrics": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dmi_median",
              "dmi_stress",
              "income_pressure_spread",
              "income_pressure_tilt",
              "most_pressured_group",
              "least_pressured_group",
              "unemployment"
            ],
            "properties": {
              "dmi_median": {
                "type": "number"
              },
              "dmi_stress": {
                "type": "number"
              },
              "income_pressure_spread": {
                "type": "number",
                "minimum": 0
              },
              "income_pressure_tilt": {
                "type": "number"
              },
              "most_pressured_group": {
                "type": "string",
                "pattern": "^Q[1-5]$"
              },
              "least_pressured_group": {
                "type": "string",
                "pattern": "^Q[1-5]$"
              },
              "unemployment": {
                "type": "number"
              }
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "spec_url_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["csv", "parquet", "release_note"],
      "properties": {
        "csv": {
          "type": "string",
          "format": "uri-reference"
        },
        "parquet": {
          "type": "string",
          "format": "uri-reference"
        },
        "release_note": {
          "type": "string",
          "format": "uri-reference"
        }
      }
    }
  }
}
