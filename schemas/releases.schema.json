{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DMI Releases Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "current_release_id",
    "releases"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_release_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "release_id",
          "data_through_label",
          "published_at",
          "status",
          "methodology_version",
          "summary",
          "urls",
          "metrics"
        ],
        "properties": {
          "release_id": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}$"
          },
          "data_through_label": {
            "type": "string"
          },
          "published_at": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": ["current", "superseded", "revised"]
          },
          "methodology_version": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "urls": {
            "type": "object",
            "additionalProperties": false,
            "required": ["csv", "parquet", "release_note"],
            "properties": {
              "csv": { "type": "string", "format": "uri-reference" },
              "parquet": { "type": "string", "format": "uri-reference" },
              "release_note": { "type": "string", "format": "uri-reference" },
              "dashboard": { "type": "string", "format": "uri-reference" },
              "repo": { "type": "string", "format": "uri-reference" }
            }
          },
          "metrics": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dmi_median",
              "dmi_stress",
              "income_pressure_gap",
              "unemployment"
            ],
            "properties": {
              "dmi_median": { "type": "number" },
              "dmi_stress": { "type": "number" },
              "income_pressure_gap": { "type": "number" },
              "unemployment": { "type": "number" }
            }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
